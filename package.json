{
  "name": "nordisign-dk",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npx @11ty/eleventy",
    "start": "npx @11ty/eleventy --serve",
    "test": "npx playwright test tests/ --reporter=list",
    "test:serve": "npx http-server . -p 8080 -s &",
    "test:screenshots": "npx playwright test tests/ --reporter=list --grep='Screenshots'"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "http-server": "^14.1.1"
  }
}
