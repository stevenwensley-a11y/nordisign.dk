      .stories-content { grid-template-columns: 1fr; gap: 40px; }
      .product-card { padding: 36px 24px; }
      .product-columns { grid-template-columns: 1fr; }
      .process-steps { grid-template-columns: 1fr 1fr; }
      .portfolio-masonry { column-count: 2; }
      .portfolio-filters { justify-content: center; }
      .why-grid { grid-template-columns: 1fr; }
      .blog-grid { column-count: 1; }
      .parallax-break { background-attachment: scroll; }
    }
    @media (max-width: 480px) {
      .process-steps { grid-template-columns: 1fr; }
      .portfolio-masonry { column-count: 1; }
      .hero-buttons { flex-direction: column; align-items: center; }
    }
  </style>
extraScripts: |
  <script>
    // Portfolio filter
    const filterBtns = document.querySelectorAll('.filter-btn');
    const portfolioItems = document.querySelectorAll('.portfolio-item');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        portfolioItems.forEach(item => {
          if (filter === 'all' || item.dataset.category === filter) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });
  </script>
