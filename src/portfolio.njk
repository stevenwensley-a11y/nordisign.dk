---
layout: base.njk
permalink: /portfolio/
title: "Portfolio — NORDI'SIGN"
description: "Udvalgte cases fra NORDI'SIGN. AI Film Making, bogdesign, AI illustrationer og PR branding af Sophia Obel."
canonical: "https://nordisign.dk/portfolio/"
ogUrl: "https://nordisign.dk/portfolio/"
ogImage: "https://nordisign.dk/assets/thumbs/thumb-chakra.jpg"
extraHead: |
  <style>
    .page-hero {
      padding: 160px 40px 80px; text-align: center; background: var(--off-white);
    }
    .page-hero .section-label {
      font-family: var(--font-body); font-size: 11px; font-weight: 500;
      letter-spacing: 4px; text-transform: uppercase; color: var(--accent); margin-bottom: 16px;
    }
    .page-hero h1 {
      font-family: var(--font-serif); font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 300; color: var(--text-dark); line-height: 1.2; margin-bottom: 16px;
    }
    .page-hero p {
      font-family: var(--font-serif); font-size: 17px; font-weight: 300;
      color: var(--text-muted); line-height: 1.8;
    }
    section { padding: 100px 40px; }
    .section-label {
      font-family: var(--font-body); font-size: 11px; font-weight: 500;
      letter-spacing: 4px; text-transform: uppercase; color: var(--accent); margin-bottom: 20px;
    }
    .portfolio { background: var(--white); }
    .portfolio-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 48px; }
    .filter-btn {
      font-family: var(--font-body); font-size: 10px; font-weight: 500;
      letter-spacing: 2px; text-transform: uppercase;
      padding: 10px 24px; border: 1px solid var(--mid-gray);
      background: transparent; color: var(--text-muted); cursor: pointer; transition: all 0.3s;
    }
    .filter-btn:hover { border-color: var(--text-dark); color: var(--text-dark); }
    .filter-btn.active { background: var(--text-dark); color: var(--white); border-color: var(--text-dark); }
    .portfolio-masonry { column-count: 3; column-gap: 16px; }
    .portfolio-item { break-inside: avoid; margin-bottom: 16px; position: relative; overflow: hidden; cursor: pointer; background: var(--light-gray); }
    .portfolio-item.hidden { display: none; }
    .portfolio-item::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.5), transparent 50%); opacity: 0; transition: opacity 0.3s; }
    .portfolio-item:hover::after { opacity: 1; }
    .portfolio-item img { width: 100%; display: block; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
    .portfolio-item:hover img { transform: scale(1.04); }
    .play-icon {
      width: 48px; height: 48px; border: 2px solid rgba(255,255,255,0.7);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      z-index: 2; position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%); transition: all 0.3s; opacity: 0;
    }
    .portfolio-item:hover .play-icon { opacity: 1; border-color: #fff; }
    .play-icon::after { content: ''; width: 0; height: 0; border-left: 14px solid #fff; border-top: 8px solid transparent; border-bottom: 8px solid transparent; margin-left: 4px; }
    .portfolio-label { position: absolute; bottom: 16px; left: 16px; z-index: 3; opacity: 0; transform: translateY(10px); transition: all 0.3s; }
    .portfolio-item:hover .portfolio-label { opacity: 1; transform: translateY(0); }
    .portfolio-label h5 { font-family: var(--font-serif); font-size: 1.1rem; color: #fff; font-weight: 400; }
    .portfolio-label span { font-family: var(--font-body); font-size: 10px; color: rgba(255,255,255,0.7); letter-spacing: 1.5px; text-transform: uppercase; }
    .portfolio-item.tall img { aspect-ratio: 3/4; object-fit: cover; }
    .portfolio-item.wide img { aspect-ratio: 16/9; object-fit: cover; }
    .portfolio-item.square img { aspect-ratio: 1/1; object-fit: cover; }
    @media (max-width: 1024px) { .portfolio-masonry { column-count: 2; } }
    @media (max-width: 768px) {
      section { padding: 80px 24px; }
      .page-hero { padding: 120px 24px 60px; }
      .portfolio-masonry { column-count: 2; }
      .portfolio-filters { justify-content: center; }
    }
    @media (max-width: 480px) { .portfolio-masonry { column-count: 1; } }
  </style>
extraScripts: |
  <script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const portfolioItems = document.querySelectorAll('.portfolio-item');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        portfolioItems.forEach(item => {
          if (filter === 'all' || item.dataset.category === filter) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });
  </script>
---

<div class="page-hero">
  <p class="section-label">Portfolio</p>
  <h1>Udvalgte cases</h1>
  <p>Et udvalg af film, design og visuelle verdener skabt med strategi og sanselighed.</p>
</div>

<section class="portfolio">
