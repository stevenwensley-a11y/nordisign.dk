      <button class="filter-btn" data-filter="bogdesign">Bogdesign</button>
      <button class="filter-btn" data-filter="ai-illustrationer">AI illustrationer</button>
      <button class="filter-btn" data-filter="ai-film">AI Film Making</button>
      <button class="filter-btn" data-filter="ai-pr-video">AI PR video</button>
      <button class="filter-btn" data-filter="pr-branding">Video for PR Branding</button>
    </div>
    <div class="portfolio-masonry fade-in">
      <div class="portfolio-item tall" data-category="ai-film">
        <img src="/assets/thumbs/thumb-nordarv.jpg" alt="NORDARV brandfilm">
        <div class="play-icon"></div>
        <div class="portfolio-label"><h5>NORDARV</h5><span>AI Film Making</span></div>
      </div>
      <div class="portfolio-item wide" data-category="ai-film">
