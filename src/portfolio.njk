      </div>
      <div class="portfolio-item square" data-category="pr-branding">
        <img src="/assets/thumbs/thumb-vanlife.jpg" alt="VANLIFE Farewell">
        <div class="play-icon"></div>
        <div class="portfolio-label"><h5>VANLIFE Farewell</h5><span>PR Branding</span></div>
      </div>
      <div class="portfolio-item tall" data-category="bogdesign">
        <img src="/assets/thumbs/thumb-skumfodt.jpg" alt="Skumf&oslash;dt bog storytelling">
        <div class="play-icon"></div>
        <div class="portfolio-label"><h5>Skumf&oslash;dt #1</h5><span>Bogdesign</span></div>
      </div>
      <div class="portfolio-item wide" data-category="bogdesign">
        <img src="/assets/thumbs/thumb-ella.jpg" alt="Ella af F&aelig;r&oslash;erne">
        <div class="play-icon"></div>
        <div class="portfolio-label"><h5>Ella af F&aelig;r&oslash;erne</h5><span>Bogdesign</span></div>
      </div>
      <div class="portfolio-item square" data-category="ai-illustrationer">
        <img src="/assets/thumbs/thumb-chakra.jpg" alt="Chakra Ladies">
        <div class="play-icon"></div>
        <div class="portfolio-label"><h5>Chakra Ladies</h5><span>AI Illustrationer</span></div>
      </div>
    </div>
  </div>
</section>
